# ═══════════════════════════════════════════════════════════
# ARCADIA SLOT BOT — Environment Configuration
# ═══════════════════════════════════════════════════════════

# ── Arcadia Authentication ────────────────────────────────
# Option A: API Token (if reverse-engineered)
ARCADIA_API_TOKEN=
ARCADIA_CSRF_TOKEN=

# Option B: Session Cookie (from browser)
ARCADIA_SESSION_COOKIE=

# Option C: Playwright storage state path (auto-generated)
ARCADIA_STORAGE_STATE_PATH=./data/auth.json

# ── X (Twitter) OAuth ─────────────────────────────────────
# Only needed if we need to re-auth programmatically
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:8000/auth/callback

# ── Bot Behavior ──────────────────────────────────────────
# Polling interval in seconds (be respectful)
POLL_INTERVAL_SECONDS=30
CAMPAIGN_FILTER_MIN_PAYOUT=0.0
CAMPAIGN_FILTER_MAX_SLOTS_PER_DAY=3
AUTO_LOCK_ENABLED=false
AUTO_LOCK_MAX_CONCURRENT=2

# ── Strategy Priority ─────────────────────────────────────
# Comma-separated: api,playwright,ai_agent
STRATEGY_PRIORITY=api,playwright,ai_agent
STRATEGY_TIMEOUT_SECONDS=10
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=300

# ── Notifications ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
NOTIFICATION_ON_LOCK=true
NOTIFICATION_ON_ERROR=true
NOTIFICATION_ON_CAMPAIGN_DROP=true

# ── AI Agent (Optional) ───────────────────────────────────
OPENAI_API_KEY=
AI_AGENT_MODEL=gpt-4o
AI_AGENT_MAX_STEPS=20

# ── Redis (Optional, for distributed session storage) ─────
REDIS_URL=redis://localhost:6379/0

# ── Server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development

# ── Monitoring ────────────────────────────────────────────
METRICS_ENABLED=true
METRICS_PORT=9090